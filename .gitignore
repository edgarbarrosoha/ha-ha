.DS_Store
node_modules/
conflict-files-obsidian-git.md
~$*

# Build artifacts — never commit
**/target/
**/dist/
**/*.rlib
**/*.dylib
**/*.rmeta

# Large binaries — use Git LFS or keep local
*.psd

# Obsidian machine-local UI state (prevents cross-device pull conflicts)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/appearance.json
.obsidian/themes/
**/.DS_Store
.claude/projects/
